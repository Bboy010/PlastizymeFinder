/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    PlastizymeFinder Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {

    // -----------------------------------------------------------------------
    // INPUT / OUTPUT
    // -----------------------------------------------------------------------
    input           = null          // Path to input samplesheet (CSV)
    outdir          = 'results'     // Output directory
    tracedir        = "${params.outdir}/pipeline_info"

    // -----------------------------------------------------------------------
    // REFERENCE
    // -----------------------------------------------------------------------
    host_genome     = null          // Path to host genome (FASTA) for decontamination

    // -----------------------------------------------------------------------
    // DATABASES
    // -----------------------------------------------------------------------
    // Provide your own paths, or leave null to auto-download at runtime

    kraken2_db      = null          // Path to Kraken2 database directory
    metaphlan4_db   = null          // Path to MetaPhlAn4 database directory
    dbcan2_db       = null          // Path to dbCAN2 database directory
    eggnog_db       = null          // Path to eggNOG database directory
    kofamscan_db    = null          // Path to KofamScan profiles directory
    gtdbtk_db       = null          // Path to GTDB-tk reference data directory

    // PET_DB : required — no auto-download (manual curation required)
    // Download: https://github.com/Bboy010/PlastizymeFinder/releases
    // Guide:    docs/pet_db_guide.md
    pet_db          = null

    // Directory where databases will be downloaded if not provided
    db_cache_dir    = "${projectDir}/databases"

    // -----------------------------------------------------------------------
    // PIPELINE OPTIONS
    // -----------------------------------------------------------------------
    skip_taxonomy   = false         // Skip taxonomic profiling (Stage 2)
    skip_annotation = false         // Skip gene annotation (Stage 6)
    skip_structure  = false         // Skip 3D structure prediction (Stage 8)

    // Assembly
    assembler       = 'megahit'     // De novo assembler (megahit only for now)
    min_contig_len  = 1000          // Minimum contig length to keep

    // Binning
    min_bin_size    = 200000        // Minimum bin size (bp) for MetaBAT2

    // Bin QC thresholds (dRep)
    min_completeness    = 50        // Minimum bin completeness (%)
    max_contamination   = 10        // Maximum bin contamination (%)

    // -----------------------------------------------------------------------
    // BOILERPLATE OPTIONS
    // -----------------------------------------------------------------------
    help            = false
    version         = false
    publish_dir_mode = 'copy'
    email           = null
    email_on_fail   = null
    multiqc_config  = null
    multiqc_title   = null
    max_multiqc_email_size = '25.MB'
    monochrome_logs = false

    // -----------------------------------------------------------------------
    // MAX RESOURCE LIMITS (overridden by profiles)
    // -----------------------------------------------------------------------
    max_cpus        = 16
    max_memory      = '128.GB'
    max_time        = '240.h'
}

// -----------------------------------------------------------------------
// PROCESS DEFAULTS
// -----------------------------------------------------------------------
process {
    cpus   = { check_max( 2    * task.attempt, 'cpus'   ) }
    memory = { check_max( 8.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h  * task.attempt, 'time'   ) }

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'
}

// -----------------------------------------------------------------------
// PROFILES
// -----------------------------------------------------------------------
profiles {

    debug {
        process.beforeScript = 'echo $HOSTNAME'
    }

    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        conda.enabled          = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }

    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }

    test {
        includeConfig 'conf/test.config'
    }

    test_full {
        includeConfig 'conf/test_full.config'
    }
}

// -----------------------------------------------------------------------
// INCLUDE CONFIGS
// -----------------------------------------------------------------------
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// -----------------------------------------------------------------------
// EXECUTION REPORTS
// -----------------------------------------------------------------------
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

timeline {
    enabled = true
    file    = "${params.tracedir}/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.tracedir}/execution_report_${trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.tracedir}/execution_trace_${trace_timestamp}.txt"
}
dag {
    enabled = true
    file    = "${params.tracedir}/pipeline_dag_${trace_timestamp}.html"
}

// -----------------------------------------------------------------------
// MANIFEST
// -----------------------------------------------------------------------
manifest {
    name            = 'PlastizymeFinder'
    author          = 'Hongo'
    homePage        = 'https://github.com/Bboy010/PlastizymeFinder'
    description     = 'Metagenomic pipeline to identify and characterize plastic-degrading enzymes'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}

// -----------------------------------------------------------------------
// HELPER FUNCTION — cap resources to max limits
// -----------------------------------------------------------------------
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) { return obj }
    }
}
