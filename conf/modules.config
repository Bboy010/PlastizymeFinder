/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    PlastizymeFinder modules configuration
    Defines ext.args and publishDir for each process
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // -----------------------------------------------------------------------
    // Stage 1 — QC & Preprocessing
    // -----------------------------------------------------------------------
    withName: 'FASTQC_RAW' {
        ext.args   = '--quiet'
        publishDir = [
            path: { "${params.outdir}/fastqc/raw" },
            mode: params.publish_dir_mode,
            pattern: '*.{html,zip}'
        ]
    }
    withName: 'FASTP' {
        ext.args   = '--qualified_quality_phred 20 --length_required 50 --detect_adapter_for_pe'
        publishDir = [
            path: { "${params.outdir}/fastp" },
            mode: params.publish_dir_mode,
            pattern: '*.{html,json,fastq.gz}'
        ]
    }
    withName: 'BOWTIE2_ALIGN_HOST' {
        ext.args   = '--very-sensitive --no-unal'
        publishDir = [
            path: { "${params.outdir}/host_removal" },
            mode: params.publish_dir_mode,
            pattern: '*.{bam,log}'
        ]
    }
    withName: 'FASTQC_TRIMMED' {
        ext.args   = '--quiet'
        publishDir = [
            path: { "${params.outdir}/fastqc/trimmed" },
            mode: params.publish_dir_mode,
            pattern: '*.{html,zip}'
        ]
    }

    // -----------------------------------------------------------------------
    // Stage 2 — Taxonomic Profiling
    // -----------------------------------------------------------------------
    withName: 'KRAKEN2' {
        ext.args   = '--report-zero-counts'
        publishDir = [
            path: { "${params.outdir}/taxonomy/kraken2" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'METAPHLAN4' {
        ext.args   = '--tax_lev a --nproc ${task.cpus}'
        publishDir = [
            path: { "${params.outdir}/taxonomy/metaphlan4" },
            mode: params.publish_dir_mode
        ]
    }

    // -----------------------------------------------------------------------
    // Stage 3 — Assembly
    // -----------------------------------------------------------------------
    withName: 'MEGAHIT' {
        ext.args   = "--min-contig-len ${params.min_contig_len}"
        publishDir = [
            path: { "${params.outdir}/assembly" },
            mode: params.publish_dir_mode,
            pattern: '*.{fa.gz,log}'
        ]
    }
    withName: 'QUAST_ASSEMBLY' {
        ext.prefix = 'assembly'
        publishDir = [
            path: { "${params.outdir}/assembly/quast" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'PRODIGAL' {
        ext.args   = '-p meta -f gff'
        publishDir = [
            path: { "${params.outdir}/assembly/prodigal" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'BOWTIE2_ALIGN_CONTIGS' {
        ext.args   = '--very-sensitive'
        publishDir = [
            path: { "${params.outdir}/assembly/coverage" },
            mode: params.publish_dir_mode
        ]
    }

    // -----------------------------------------------------------------------
    // Stage 4 — Binning
    // -----------------------------------------------------------------------
    withName: 'METABAT2' {
        ext.args   = "--minContig ${params.min_contig_len} --minClsSize ${params.min_bin_size}"
        publishDir = [
            path: { "${params.outdir}/binning/metabat2" },
            mode: params.publish_dir_mode
        ]
    }

    // -----------------------------------------------------------------------
    // Stage 5 — Bin QC
    // -----------------------------------------------------------------------
    withName: 'QUAST_BINS' {
        ext.prefix = 'bins'
        publishDir = [
            path: { "${params.outdir}/bin_qc/quast" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'DREP' {
        ext.args   = [
            "-comp ${params.min_completeness}",
            "-con ${params.max_contamination}"
        ].join(' ')
        publishDir = [
            path: { "${params.outdir}/bin_qc/drep" },
            mode: params.publish_dir_mode
        ]
    }

    // -----------------------------------------------------------------------
    // Stage 6 — Bin Classification & Annotation
    // -----------------------------------------------------------------------
    withName: 'PROKKA' {
        ext.args   = '--metagenome --compliant'
        publishDir = [
            path: { "${params.outdir}/annotation/prokka" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'CDHIT' {
        ext.args   = '-c 0.95 -n 8 -M 0 -T 0'
        publishDir = [
            path: { "${params.outdir}/annotation/cdhit" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'GTDBTK_CLASSIFYWF' {
        publishDir = [
            path: { "${params.outdir}/taxonomy/gtdbtk" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'EGGNOG_MAPPER' {
        ext.args   = '--itype proteins'
        publishDir = [
            path: { "${params.outdir}/annotation/eggnog" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'DBCAN2' {
        publishDir = [
            path: { "${params.outdir}/annotation/dbcan2" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'KOFAMSCAN' {
        publishDir = [
            path: { "${params.outdir}/annotation/kofamscan" },
            mode: params.publish_dir_mode
        ]
    }

    // -----------------------------------------------------------------------
    // Stage 7 — Plastizyme Prediction
    // -----------------------------------------------------------------------
    withName: 'METATARENZ' {
        publishDir = [
            path: { "${params.outdir}/plastizyme_prediction/metatarenz" },
            mode: params.publish_dir_mode
        ]
    }

    // -----------------------------------------------------------------------
    // Stage 8 — 3D Structure Prediction
    // -----------------------------------------------------------------------
    withName: 'CDSEARCH' {
        publishDir = [
            path: { "${params.outdir}/structure/cdsearch" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'ALPHAFOLD2' {
        publishDir = [
            path: { "${params.outdir}/structure/alphafold2" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'TMALIGN' {
        publishDir = [
            path: { "${params.outdir}/structure/tmalign" },
            mode: params.publish_dir_mode
        ]
    }
}
