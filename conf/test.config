/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    PlastizymeFinder test configuration
    Run with: nextflow run main.nf -profile test,docker --outdir results_test
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Limit resources for CI
    max_cpus   = 4
    max_memory = '12.GB'
    max_time   = '6.h'

    // Input — small synthetic metagenome (to be added in assets/testdata/)
    input   = "${projectDir}/assets/testdata/samplesheet_test.csv"

    // PET_DB — small test FASTA (10 sequences)
    pet_db  = "${projectDir}/assets/testdata/pet_db_test.fasta"

    // Skip heavy stages in test mode
    skip_structure  = true    // AlphaFold2 needs GPU
    skip_taxonomy   = false

    // Use prebuilt tiny databases for test
    kraken2_db    = null      // auto-download mini DB
    metaphlan4_db = null

    // Restrict assembly
    min_contig_len = 500
    min_bin_size   = 10000
}
