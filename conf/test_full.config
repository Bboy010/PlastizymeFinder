/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    PlastizymeFinder full test configuration
    Run with: nextflow run main.nf -profile test_full,docker --outdir results_full
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Full test dataset — runs all stages including AlphaFold2'

    max_cpus   = 16
    max_memory = '128.GB'
    max_time   = '240.h'

    input   = "${projectDir}/assets/testdata/samplesheet_test_full.csv"
    pet_db  = "${projectDir}/assets/testdata/pet_db_test.fasta"

    skip_structure = false
    skip_taxonomy  = false
}
